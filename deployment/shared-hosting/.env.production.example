APP_NAME="Mantau Umroh"
APP_TIMEZONE=Asia/Makassar
APP_ENV=production
APP_KEY=SALIN_APP_KEY_DARI_ENV_LOKAL
APP_DEBUG=false
APP_URL=https://mantauumroh.web.id
SEED_DEMO_DATA=false

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=ISI_HOST_DATABASE_HOSTINGER
DB_PORT=3306
DB_DATABASE=ISI_NAMA_DATABASE_HOSTINGER
DB_USERNAME=ISI_USERNAME_DATABASE_HOSTINGER
DB_PASSWORD=ISI_PASSWORD_DATABASE_HOSTINGER

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=mantauumroh.web.id
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@mantauumroh.web.id"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
